//- Navbar dinámica según rol del usuario
nav.navbar.navbar-expand-lg.navbar-dark.fixed-top
  .container
    a.navbar-brand.d-flex.align-items-center(href='/')
      i.bi.bi-trophy-fill.me-2.text-gold
      span.fw-bold GYM 
      span.text-gold PLATINUM

    button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarNav')
      span.navbar-toggler-icon

    #navbarNav.collapse.navbar-collapse
      if user
        //- Menú para CLIENTE
        if user.rol === 'cliente'
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href='/cliente/dashboard')
                i.bi.bi-speedometer2.me-1
                | Dashboard
            li.nav-item
              a.nav-link(href='/rutinas')
                i.bi.bi-clipboard-check.me-1
                | Rutinas
            li.nav-item
              a.nav-link(href='/cliente/membresia')
                i.bi.bi-card-checklist.me-1
                | Mi Membresía
            li.nav-item
              a.nav-link(href='/cliente/rutinas')
                i.bi.bi-calendar-check.me-1
                | Mis Rutinas
            li.nav-item
              a.nav-link(href='/cliente/pagos')
                i.bi.bi-cash-stack.me-1
                | Mis Pagos
            if tipoMembresia === 'premium'
              li.nav-item
                a.nav-link(href='/cliente/progreso')
                  i.bi.bi-graph-up-arrow.me-1
                  | Mi Progreso
              li.nav-item
                a.nav-link(href='/cliente/chat')
                  i.bi.bi-chat-dots.me-1
                  | Chat

        //- Menú para ADMIN
        if user.rol === 'admin'
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href='/admin/dashboard')
                i.bi.bi-speedometer2.me-1
                | Dashboard
            li.nav-item
              a.nav-link(href='/admin/usuarios')
                i.bi.bi-people-fill.me-1
                | Usuarios
            li.nav-item
              a.nav-link(href='/admin/membresias')
                i.bi.bi-card-checklist.me-1
                | Membresías
            li.nav-item
              a.nav-link(href='/admin/reportes')
                i.bi.bi-graph-up.me-1
                | Reportes
            li.nav-item
              a.nav-link(href='/admin/entrenadores/crear')
                i.bi.bi-person-plus-fill.me-1
                | Crear Entrenador
            li.nav-item
              a.nav-link(href='/admin/solicitudes')
                i.bi.bi-envelope-fill.me-1
                | Solicitudes

        //- Menú para ENTRENADOR
        if user.rol === 'entrenador'
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href='/entrenador/dashboard')
                i.bi.bi-speedometer2.me-1
                | Dashboard
            li.nav-item
              a.nav-link(href='/entrenador/rutinas')
                i.bi.bi-clipboard-check.me-1
                | Mis Rutinas
            li.nav-item
              a.nav-link(href='/entrenador/solicitudes', class=(activeTab === 'solicitudes' ? 'active text-warning' : ''))
                i.bi.bi-envelope-fill.me-1
                | Solicitudes
            li.nav-item
              a.nav-link(href='/entrenador/solicitudes-rutina', class=(activeTab === 'solicitudes-rutina' ? 'active text-warning' : ''))
                i.bi.bi-clipboard2-pulse.me-1
                | Sol. Rutinas
            li.nav-item
              a.nav-link(href='/entrenador/clientes-personalizados')
                i.bi.bi-person-gear.me-1
                | Personalizados
            li.nav-item
              a.nav-link(href='/entrenador/seguimiento')
                i.bi.bi-graph-up-arrow.me-1
                | Seguimiento
            li.nav-item
              a.nav-link(href='/entrenador/chat')
                i.bi.bi-chat-dots.me-1
                | Chat

        //- Menú de usuario (derecha)
        ul.navbar-nav.ms-auto
          //- Dropdown de Notificaciones
          li.nav-item.dropdown
            a.nav-link.position-relative.dropdown-toggle-no-caret#campanaNotif(href='#', role='button', data-bs-toggle='dropdown', data-bs-auto-close='outside')
              i.bi.bi-bell-fill.fs-5(class=notificacionesNoLeidas > 0 ? 'text-gold' : 'text-muted')
              if notificacionesNoLeidas > 0
                span.position-absolute.top-0.start-100.translate-middle.badge.rounded-pill.bg-danger.notif-badge#badgeNotif
                  = notificacionesNoLeidas
            ul.dropdown-menu.dropdown-menu-end.dropdown-menu-dark.notif-dropdown(style='min-width: 340px; max-height: 420px; overflow-y: auto;')
              li
                .dropdown-header.d-flex.justify-content-between.align-items-center.px-3.py-2
                  span.fw-bold.text-white
                    i.bi.bi-bell.me-1
                    | Notificaciones
                  if notificacionesNoLeidas > 0
                    span.badge.bg-gold.text-dark= notificacionesNoLeidas
              li
                hr.dropdown-divider
              if ultimasNotificaciones && ultimasNotificaciones.length > 0
                each notif in ultimasNotificaciones
                  li
                    a.dropdown-item.py-3.px-3.notif-item(href=`/notificaciones/leida/${notif.id}`, class=!notif.leido ? 'notif-unread-item' : '')
                      .d-flex.align-items-start
                        .me-2.mt-1
                          if notif.leido
                            i.bi.bi-circle.text-muted(style='font-size: 0.5rem')
                          else
                            i.bi.bi-circle-fill.text-gold(style='font-size: 0.5rem')
                        div
                          p.mb-1.small.text-light(style='white-space: normal; line-height: 1.4')= notif.mensaje
                          small.text-muted
                            i.bi.bi-clock.me-1
                            = new Date(notif.fecha).toLocaleDateString('es-MX', { day: 'numeric', month: 'short' })
                li
                  hr.dropdown-divider
                li.text-center.py-2
                  a.text-gold.fw-semibold.small.text-decoration-none(href='/notificaciones')
                    | Ver todas las notificaciones
                    i.bi.bi-arrow-right.ms-1
              else
                li
                  .text-center.py-4.px-3
                    i.bi.bi-bell-slash.text-muted.fs-4.d-block.mb-2
                    span.text-muted.small Sin notificaciones

          //- Dropdown de usuario
          li.nav-item.dropdown
            a.nav-link.dropdown-toggle.d-flex.align-items-center(href='#', role='button', data-bs-toggle='dropdown')
              .user-avatar.me-2
                i.bi.bi-person-circle
              span= user.nombre
            ul.dropdown-menu.dropdown-menu-end.dropdown-menu-dark
              li
                a.dropdown-item(href=user.rol === 'cliente' ? '/cliente/perfil' : '#')
                  i.bi.bi-person.me-2
                  | Mi Perfil
              li
                a.dropdown-item(href='/notificaciones')
                  i.bi.bi-bell.me-2
                  | Notificaciones
                  if notificacionesNoLeidas > 0
                    span.badge.bg-danger.ms-2= notificacionesNoLeidas
              li
                hr.dropdown-divider
              li
                a.dropdown-item.text-danger(href='/logout')
                  i.bi.bi-box-arrow-right.me-2
                  | Cerrar Sesión
      else
        ul.navbar-nav.ms-auto
          li.nav-item
            a.nav-link(href='/login')
              i.bi.bi-box-arrow-in-right.me-1
              | Iniciar Sesión
          li.nav-item
            a.nav-link.btn-gold-outline.ms-2.px-3(href='/registro') Registrarse

//- Script: auto-marcar notificaciones como leídas al abrir el dropdown de la campana
script.
  (function() {
    var campana = document.getElementById('campanaNotif');
    if (campana) {
      var yaLeidas = false;
      campana.addEventListener('click', function() {
        if (yaLeidas) return;
        var badge = document.getElementById('badgeNotif');
        // Solo si hay badge de notificaciones no leídas
        if (!badge) return;
        yaLeidas = true;
        fetch('/notificaciones/marcar-leidas', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin'
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.ok) {
            // Quitar badge rojo
            if (badge) badge.remove();
            // Quitar clase text-gold del icono
            var icono = campana.querySelector('.bi-bell-fill');
            if (icono) {
              icono.classList.remove('text-gold');
              icono.classList.add('text-muted');
            }
            // Quitar badge del dropdown de usuario
            var badgeUsuario = document.querySelector('.dropdown-menu-dark .badge.bg-danger');
            if (badgeUsuario) badgeUsuario.remove();
          }
        })
        .catch(function(e) { console.warn('Error al marcar notificaciones:', e); });
      });
    }
  })();
