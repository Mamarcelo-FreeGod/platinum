extends ../layout

block content
  .auth-container
    .container
      .row.justify-content-center.align-items-center.min-vh-100
        .col-md-6.col-lg-5
          .card.auth-card.shadow-lg.border-0
            .card-body.p-4.p-md-5
              .text-center.mb-4
                i.bi.bi-trophy-fill.text-gold.display-4
                h2.fw-bold.mt-3.text-white GYM #[span.text-gold PLATINUM]
                p.text-muted Crea tu cuenta gratuita

              form(action='/registro', method='POST')
                .form-floating.mb-3
                  input#nombre.form-control(type='text', name='nombre', placeholder='Tu nombre', required)
                  label(for='nombre')
                    i.bi.bi-person.me-2
                    | Nombre completo

                .form-floating.mb-3
                  input#correo.form-control(type='email', name='correo', placeholder='correo@ejemplo.com', required)
                  label(for='correo')
                    i.bi.bi-envelope.me-2
                    | Correo electrónico

                .form-floating.mb-3
                  input#telefono.form-control(type='tel', name='telefono', placeholder='Teléfono')
                  label(for='telefono')
                    i.bi.bi-telephone.me-2
                    | Teléfono (opcional)

                .form-floating.mb-3
                  input#password.form-control(type='password', name='password', placeholder='Contraseña', required, minlength='6')
                  label(for='password')
                    i.bi.bi-lock.me-2
                    | Contraseña

                .form-floating.mb-4
                  input#password2.form-control(type='password', name='password2', placeholder='Confirmar contraseña', required)
                  label(for='password2')
                    i.bi.bi-lock-fill.me-2
                    | Confirmar contraseña

                button.btn.btn-gold.w-100.py-3.fw-semibold(type='submit')
                  i.bi.bi-person-plus.me-2
                  | Crear Cuenta

              .text-center.mt-4
                p.text-muted.mb-0 ¿Ya tienes cuenta?
                a.text-gold.fw-semibold.text-decoration-none(href='/login') Inicia sesión aquí
