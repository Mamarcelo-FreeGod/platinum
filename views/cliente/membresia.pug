extends ../layout

block content
  .container.py-4
    h2.fw-bold.text-white.mb-4
      i.bi.bi-card-checklist.text-gold.me-2
      | Mi Membresía

    if membresia
      .row
        .col-lg-8
          .card.border-0.shadow-sm.glass-card.mb-4
            .card-body.p-4
              .d-flex.justify-content-between.align-items-start.mb-3
                div
                  h4.fw-bold.text-gold.mb-1= membresia.nombre
                  p.text-muted.mb-0= membresia.descripcion
                div.text-end
                  span.badge.bg-success.fs-6 Activa
                  if membresia.tipo
                    br
                    if membresia.tipo === 'basica'
                      span.badge.plan-badge-basica.mt-2 Básica
                    else if membresia.tipo === 'plus'
                      span.badge.plan-badge-plus.mt-2 Plus
                    else if membresia.tipo === 'premium'
                      span.badge.plan-badge-premium.mt-2 Premium

              hr.border-secondary

              .row.g-3
                .col-md-4
                  .text-muted.small Precio
                  h5.fw-bold.text-white $#{parseFloat(membresia.precio).toLocaleString('es-MX', {minimumFractionDigits: 2})}
                .col-md-4
                  .text-muted.small Fecha inicio
                  h5.fw-bold.text-white= new Date(membresia.fecha_inicio).toLocaleDateString('es-MX')
                .col-md-4
                  .text-muted.small Fecha vencimiento
                  h5.fw-bold.text-white= new Date(membresia.fecha_fin).toLocaleDateString('es-MX')

              //- Days remaining
              - var hoy = new Date()
              - var fin = new Date(membresia.fecha_fin)
              - var diasRestantes = Math.ceil((fin - hoy) / (1000 * 60 * 60 * 24))
              .mt-3
                .d-flex.justify-content-between.mb-1
                  span.text-muted Días restantes
                  span.fw-bold.text-gold #{diasRestantes} días
                .progress.bg-dark(style='height: 8px')
                  .progress-bar.bg-gold(style=`width: ${Math.max(0, Math.min(100, (diasRestantes / membresia.duracion) * 100))}%`)

        .col-lg-4
          .card.border-0.shadow-sm.glass-card
            .card-body.p-4.text-center
              i.bi.bi-shield-check.display-4.text-gold
              h5.fw-bold.text-white.mt-3 Estado de Membresía
              p.text-success.fw-semibold
                i.bi.bi-check-circle.me-1
                | Activa y vigente

    else
      .card.border-0.shadow-sm.glass-card.mb-4
        .card-body.p-5.text-center
          i.bi.bi-card-checklist.display-3.text-muted
          h4.fw-bold.text-white.mt-3 No tienes membresía activa
          p.text-muted Selecciona una membresía de la lista de abajo y envía tu solicitud

    //- Solicitudes pendientes
    if solicitudes && solicitudes.length > 0
      h4.fw-bold.text-white.mt-5.mb-3
        i.bi.bi-clock-history.text-gold.me-2
        | Mis Solicitudes
      .card.border-0.shadow-sm.glass-card.mb-4
        .card-body.p-0
          .table-responsive
            table.table.table-dark-custom.mb-0
              thead
                tr
                  th Membresía
                  th Precio
                  th Método
                  th Fecha
                  th Estado
              tbody
                each solicitud in solicitudes
                  tr
                    td.fw-semibold.text-gold= solicitud.membresia_nombre
                    td $#{parseFloat(solicitud.membresia_precio).toLocaleString('es-MX', {minimumFractionDigits: 2})}
                    td
                      if solicitud.metodo_pago === 'transferencia'
                        span.badge.bg-info
                          i.bi.bi-bank.me-1
                          | Transferencia
                      else
                        span.badge.bg-success
                          i.bi.bi-cash.me-1
                          | Efectivo
                    td= new Date(solicitud.created_at).toLocaleDateString('es-MX')
                    td
                      if solicitud.estado === 'pendiente'
                        span.badge.bg-warning.text-dark
                          i.bi.bi-clock.me-1
                          | Pendiente
                      else if solicitud.estado === 'aceptada'
                        span.badge.bg-success
                          i.bi.bi-check-circle.me-1
                          | Aceptada
                      else
                        span.badge.bg-danger
                          i.bi.bi-x-circle.me-1
                          | Rechazada

    //- ==================== PLANES DE MEMBRESÍA (DINÁMICOS) ====================
    .text-center.mt-5.mb-4
      h3.display-6.fw-bold.text-white
        i.bi.bi-gem.text-gold.me-2
        | Planes de Membresía
      p.text-secondary.fs-5 Elige el plan que se adapte mejor a tus objetivos

    //- Variables auxiliares para saber si hay solicitud pendiente
    - var tienePendiente = solicitudes && solicitudes.some(s => s.estado === 'pendiente')
    - var tipoActual = membresia ? membresia.tipo : null
    //- Jerarquía: basica=1, plus=2, premium=3
    - var jerarquia = { basica: 1, plus: 2, premium: 3 }
    - var nivelActual = tipoActual ? jerarquia[tipoActual] : 0

    //- Plan Cards - DINÁMICOS desde la base de datos
    .row.g-4.mb-5
      each m in todasMembresias
        if m.activa
          .col-md-4
            - var esActual = membresia && membresia.tipo === m.tipo
            - var esBasica = m.tipo === 'basica'
            - var esPlus = m.tipo === 'plus'
            - var esPremium = m.tipo === 'premium'
            - var nivelPlan = jerarquia[m.tipo] || 0
            - var esDowngrade = nivelActual > 0 && nivelPlan < nivelActual
            - var esUpgrade = nivelActual > 0 && nivelPlan > nivelActual

            .card.h-100.text-center.overflow-hidden.position-relative(
              class=`plan-card plan-card-${m.tipo}${esActual ? ' plan-actual' : ''}`
            )
              //- Badge "Más popular" solo para Premium
              if esPremium
                .plan-popular-badge
                  i.bi.bi-trophy-fill.me-1
                  | Más popular

              //- Badge "Tu plan actual"
              if esActual
                .plan-actual-badge
                  i.bi.bi-check-circle-fill.me-1
                  | Tu plan actual

              .card-body.p-4.d-flex.flex-column
                //- Icono del plan
                .plan-icon-wrapper.mx-auto.mb-3(class=`plan-icon-${m.tipo}`)
                  if esBasica
                    i.bi.bi-lightning-charge.fs-1
                  else if esPlus
                    i.bi.bi-stars.fs-1
                  else if esPremium
                    i.bi.bi-gem.fs-1

                //- Nombre desde DB
                h4.fw-bold.text-white.mb-1= m.nombre

                //- Precio DINÁMICO desde DB
                .plan-price.my-3(class=esPremium ? 'plan-price-premium' : '')
                  span.plan-currency $
                  span.plan-amount #{Math.round(parseFloat(m.precio))}
                  span.plan-period /mes

                //- Descripción desde DB
                p.text-muted.small.mb-4= m.descripcion

                //- Features estáticas por tipo
                ul.plan-features.text-start.mb-4
                  if esBasica
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Ver rutinas preestablecidas
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Ver GIFs de ejercicios
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Instalaciones básicas (gimnasio físico)
                    li.plan-feature-no
                      i.bi.bi-x-circle-fill.text-danger.me-2.opacity-50
                      span.text-muted Rutinas personalizadas
                    li.plan-feature-no
                      i.bi.bi-x-circle-fill.text-danger.me-2.opacity-50
                      span.text-muted Seguimiento (Mi Progreso)

                  else if esPlus
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Todo lo de Básica
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | 1 Rutina personalizada al mes
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Acceso a GIFs
                    li.plan-feature-no
                      i.bi.bi-x-circle-fill.text-danger.me-2.opacity-50
                      span.text-muted Seguimiento de progreso

                  else if esPremium
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Todo lo de Plus
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Rutinas personalizadas ilimitadas
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Seguimiento personalizado (Mi Progreso)
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Prioridad con entrenador
                    li.plan-feature-yes
                      i.bi.bi-check-circle-fill.text-success.me-2
                      | Regalderas, lockers e inst. Premium

                //- Botón de solicitar con lógica de upgrade/downgrade
                .mt-auto
                  if esActual
                    //- Plan actual: deshabilitado
                    button.btn.btn-outline-success.w-100(disabled)
                      i.bi.bi-check-circle.me-1
                      | Plan Activo
                  else if tienePendiente
                    //- Tiene solicitud pendiente: deshabilitado
                    button.btn.btn-outline-secondary.w-100(disabled)
                      i.bi.bi-clock.me-1
                      | Solicitud pendiente
                  else if esDowngrade
                    //- Plan inferior: bloqueado
                    button.btn.btn-outline-secondary.w-100(disabled)
                      i.bi.bi-lock.me-1
                      | Plan inferior
                  else if tipoActual === 'premium'
                    //- Premium ya tiene el máximo: todos bloqueados
                    button.btn.btn-outline-secondary.w-100(disabled)
                      i.bi.bi-shield-check.me-1
                      | Ya tienes el máximo
                  else
                    //- Puede solicitar (upgrade o nuevo)
                    form(action='/cliente/membresia/solicitar', method='POST')
                      input(type='hidden', name='membresia_id', value=m.id)
                      .mb-2
                        select.form-select.form-select-sm(name='metodo_pago', required)
                          option(value='', disabled, selected) Método de pago
                          option(value='efectivo') 💵 Efectivo
                          option(value='transferencia') 🏦 Transferencia
                      if esUpgrade
                        button.btn.btn-gold.w-100(type='submit')
                          i.bi.bi-arrow-up-circle.me-1
                          | Mejorar Plan
                      else if esPremium
                        button.btn.btn-premium.w-100(type='submit')
                          i.bi.bi-gem.me-1
                          | Elegir Plan
                      else if esPlus
                        button.btn.btn-gold.w-100(type='submit')
                          i.bi.bi-send.me-1
                          | Elegir Plan
                      else
                        button.btn.btn-outline-gold.w-100(type='submit')
                          i.bi.bi-send.me-1
                          | Elegir Plan

    //- ==================== TABLA COMPARATIVA ====================
    .card.glass-card.mb-5
      .card-header
        h5.mb-0.fw-bold.text-light
          i.bi.bi-table.me-2.text-gold
          | Comparativa de Planes
      .card-body.p-0
        .table-responsive
          table.table.table-dark-custom.plan-comparison-table.mb-0
            thead
              tr
                th.text-start Función
                th.text-center
                  span.plan-badge-basica Básica
                th.text-center
                  span.plan-badge-plus Plus
                th.text-center
                  span.plan-badge-premium Premium
            tbody
              tr
                td.text-start
                  i.bi.bi-clipboard-plus.text-gold.me-2
                  | Rutina personalizada
                td.text-center
                  i.bi.bi-x-lg.text-danger
                td.text-center
                  span.text-success 1 al mes
                td.text-center
                  span.text-success.fw-bold Ilimitada
              tr
                td.text-start
                  i.bi.bi-filetype-gif.text-gold.me-2
                  | GIFs de ejercicios
                td.text-center
                  i.bi.bi-check-lg.text-success
                td.text-center
                  i.bi.bi-check-lg.text-success
                td.text-center
                  i.bi.bi-check-lg.text-success
              tr
                td.text-start
                  i.bi.bi-graph-up.text-gold.me-2
                  | Seguimiento (Mi Progreso)
                td.text-center
                  i.bi.bi-x-lg.text-danger
                td.text-center
                  i.bi.bi-x-lg.text-danger
                td.text-center
                  span.text-success.fw-bold Completo
              tr
                td.text-start
                  i.bi.bi-building.text-gold.me-2
                  | Instalaciones
                td.text-center
                  span.text-muted Básicas
                td.text-center
                  span.text-muted Básicas
                td.text-center
                  span.text-success.fw-bold Premium (Lockers, etc)

