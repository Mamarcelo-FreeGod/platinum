extends ../layout

block content
  .container.py-4
    //- Header
    .d-flex.align-items-center.mb-4
      a.btn.btn-outline-gold.me-3(href='/cliente/progreso')
        i.bi.bi-arrow-left
      div
        h1.fw-bold.mb-0
          i.bi.bi-chat-dots-fill.text-gold.me-2
          | Chat con Entrenador
        p.text-secondary.mb-0 Comunicación directa con tu entrenador personal

    .row.g-4
      //- Contact List
      .col-lg-4
        .card.glass-card.h-100
          .card-header
            h6.mb-0.fw-bold.text-light
              i.bi.bi-people-fill.me-2.text-gold
              | Entrenadores
          .card-body.p-0
            if contactos && contactos.length > 0
              .list-group.list-group-flush
                each c in contactos
                  a.list-group-item.list-group-item-action.chat-contact-item(
                    href=`/cliente/chat?con=${c.contacto_id}`,
                    class=contactoActual && contactoActual.id === c.contacto_id ? 'active' : ''
                  )
                    .d-flex.align-items-center.gap-3
                      .chat-avatar
                        i.bi.bi-person-badge-fill
                      .flex-grow-1.overflow-hidden
                        .d-flex.justify-content-between.align-items-center
                          h6.mb-0.fw-bold.text-truncate= c.contacto_nombre
                          if c.no_leidos > 0
                            span.badge.bg-gold.text-dark.rounded-pill= c.no_leidos
                        if c.ultimo_mensaje
                          small.text-muted.text-truncate.d-block= c.ultimo_mensaje
                        else
                          small.text-muted Envía el primer mensaje
            else
              .text-center.py-5
                i.bi.bi-chat-left-text.display-4.text-muted.d-block.mb-3(style='opacity:0.3')
                p.text-muted No tienes entrenadores asignados aún

      //- Chat Area
      .col-lg-8
        .card.glass-card.h-100.d-flex.flex-column
          if contactoActual
            //- Chat Header
            .card-header.d-flex.align-items-center.gap-3
              .chat-avatar-sm
                i.bi.bi-person-badge-fill
              div
                h6.mb-0.fw-bold.text-light= contactoActual.nombre
                small.text-muted Entrenador

            //- Messages Container
            .card-body.chat-messages-container.flex-grow-1#chatMessages
              if mensajes && mensajes.length > 0
                each msg in mensajes
                  if msg.emisor_id === userId
                    .chat-bubble.chat-bubble-sent
                      .chat-bubble-content= msg.mensaje
                      .chat-bubble-time= new Date(msg.created_at).toLocaleString('es-MX', { hour:'2-digit', minute:'2-digit', day:'2-digit', month:'short' })
                  else
                    .chat-bubble.chat-bubble-received
                      .chat-bubble-content= msg.mensaje
                      .chat-bubble-time= new Date(msg.created_at).toLocaleString('es-MX', { hour:'2-digit', minute:'2-digit', day:'2-digit', month:'short' })
              else
                .text-center.py-5
                  i.bi.bi-chat-square-text.display-4.text-muted.d-block.mb-3(style='opacity:0.3')
                  p.text-muted Inicia la conversación enviando un mensaje

            //- Message Input
            .card-footer
              form.d-flex.gap-2(action='/cliente/chat/send', method='POST')
                input(type='hidden', name='receptor_id', value=contactoActual.id)
                input.form-control.flex-grow-1(type='text', name='mensaje', placeholder='Escribe un mensaje...', required, autocomplete='off')
                button.btn.btn-gold(type='submit')
                  i.bi.bi-send-fill
          else
            .card-body.d-flex.align-items-center.justify-content-center
              .text-center
                i.bi.bi-chat-dots.display-3.text-muted.d-block.mb-3(style='opacity:0.2')
                h5.text-secondary Selecciona un entrenador para chatear

  //- Auto-scroll to bottom
  script.
    document.addEventListener('DOMContentLoaded', function() {
      var container = document.getElementById('chatMessages');
      if (container) {
        container.scrollTop = container.scrollHeight;
      }
    });
