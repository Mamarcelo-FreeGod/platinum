-extends ../layout

block content
  .container.py-4
    //- Header
    .d-flex.align-items-center.mb-4
      a.btn.btn-outline-gold.me-3(href='/rutinas')
        i.bi.bi-arrow-left
      div
        h1.display-6.fw-bold
          i.bi.bi-person-gear.me-2.text-gold
          | Solicitar Rutina Personalizada
        p.text-secondary.mb-0 Completa tus datos para que un entrenador diseñe una rutina ideal para ti.

    .row.justify-content-center
      .col-lg-8
        .card.glass-card
          .card-body.p-4.p-md-5
            //- Plan badge
            if tipoMembresia
              .text-center.mb-4
                if tipoMembresia === 'plus'
                  span.badge.plan-badge-plus.fs-6
                    i.bi.bi-star-half.me-1
                    | Plan Plus — 1 rutina personalizada al mes
                else if tipoMembresia === 'premium'
                  span.badge.plan-badge-premium.fs-6
                    i.bi.bi-star-fill.me-1
                    | Plan Premium — Rutinas ilimitadas

            //- Límite alcanzado (Plus)
            if limiteAlcanzado
              .alert.alert-warning.border-0.mb-4(role='alert')
                i.bi.bi-exclamation-triangle-fill.me-2
                strong ¡Límite alcanzado!
                |  Tu plan Plus permite 1 rutina personalizada al mes. 
                a.text-gold.fw-bold(href='/cliente/membresia') Mejora a Premium
                |  para rutinas ilimitadas.

            //- Ya tiene solicitud pendiente
            else if yaPendiente
              .alert.alert-info.border-0.mb-4(role='alert')
                i.bi.bi-hourglass-split.me-2
                strong Ya tienes una solicitud pendiente.
                |  Un entrenador está revisando tu solicitud. Te notificaremos cuando esté lista.

            //- Formulario
            else
              //- Info alert
              .alert.alert-info.border-0.mb-4(role='alert')
                i.bi.bi-info-circle-fill.me-2
                | Un entrenador profesional revisará tu solicitud y creará una rutina adaptada a tus necesidades.

              form(action='/cliente/solicitar-rutina', method='POST')
                if !tieneInfoPrevia
                  .row.g-4
                    //- Peso
                    .col-md-6
                      label.form-label(for='peso')
                        i.bi.bi-speedometer.me-1.text-gold
                        | Peso (kg)
                      .input-group
                        input.form-control#peso(
                          type='number',
                          name='peso',
                          step='0.01',
                          min='30',
                          max='300',
                          placeholder='Ej: 75.5',
                          required
                        )
                        span.input-group-text kg

                    //- Estatura
                    .col-md-6
                      label.form-label(for='estatura')
                        i.bi.bi-rulers.me-1.text-gold
                        | Estatura (cm)
                      .input-group
                        input.form-control#estatura(
                          type='number',
                          name='estatura',
                          step='0.01',
                          min='100',
                          max='250',
                          placeholder='Ej: 175',
                          required
                        )
                        span.input-group-text cm

                    //- Sexo
                    .col-md-6
                      label.form-label(for='sexo')
                        i.bi.bi-gender-ambiguous.me-1.text-gold
                        | Sexo
                      select.form-select#sexo(name='sexo', required)
                        option(value='', disabled, selected) Selecciona...
                        option(value='Masculino') Masculino
                        option(value='Femenino') Femenino
                        option(value='Otro') Otro

                    //- Condición especial
                    .col-12
                      label.form-label(for='condicion')
                        i.bi.bi-clipboard2-pulse.me-1.text-gold
                        | Condición especial u objetivos
                      textarea.form-control#condicion(
                        name='condicion',
                        rows='4',
                        placeholder='Ejemplo: Tengo una lesión en la rodilla izquierda. Mi objetivo es ganar masa muscular en tren superior.'
                      )
                      .form-text.text-muted Describe lesiones, condiciones médicas, objetivos o cualquier información relevante.
                else
                  .row.g-4
                    .col-md-6
                      label.form-label(for='tipo_solicitud')
                        i.bi.bi-gear-fill.me-1.text-gold
                        | Tipo de solicitud
                      select.form-select#tipo_solicitud(name='tipo_solicitud', required)
                        option(value='cambio_rutina') Cambio de rutina
                        option(value='cambio_ejercicio') Cambio de ejercicio
                        option(value='reducir_dias') Reducir días de entrenamiento
                        option(value='aumentar_dias') Aumentar días de entrenamiento

                    .col-md-6
                      label.form-label(for='rutina_id')
                        i.bi.bi-card-checklist.me-1.text-gold
                        | Rutina asociada (Opcional)
                      select.form-select#rutina_id(name='rutina_id')
                        option(value='') Seleccionar rutina...
                        if rutinas && rutinas.length > 0
                          each rutina in rutinas
                            option(value=rutina.id)= rutina.nombre + (rutina.dia_semana ? ` (${rutina.dia_semana})` : '')

                    .col-12
                      label.form-label(for='descripcion')
                        i.bi.bi-pencil-fill.me-1.text-gold
                        | Descripción
                      textarea.form-control#descripcion(
                        name='descripcion',
                        rows='4',
                        required,
                        placeholder='Ej: Quiero cambiar el press plano por mancuernas, o ya no podré ir los viernes...'
                      )

                  //- Submit
                .col-12.text-center.pt-3
                  button.btn.btn-gold.btn-lg.px-5(type='submit')
                    i.bi.bi-send-fill.me-2
                    | Enviar Solicitud
