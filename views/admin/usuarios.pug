extends ../layout

block content
  .container.py-4
    .d-flex.justify-content-between.align-items-center.mb-4
      h2.fw-bold.text-white.mb-0
        i.bi.bi-people-fill.text-gold.me-2
        | Gestión de Usuarios
      a.btn.btn-gold(href='/admin/usuarios/crear')
        i.bi.bi-person-plus.me-2
        | Nuevo Usuario

    .card.border-0.shadow-sm.glass-card
      .card-body.p-0
        .table-responsive
          table.table.table-dark-custom.mb-0
            thead
              tr
                th #
                th Nombre
                th Correo
                th Teléfono
                th Rol
                th Estado
                th Registro
                th Acciones
            tbody
              if usuarios && usuarios.length > 0
                each usuario in usuarios
                  tr
                    td.text-muted= usuario.id
                    td.fw-semibold= usuario.nombre
                    td= usuario.correo
                    td= usuario.telefono || '—'
                    td
                      if usuario.rol === 'admin'
                        span.badge.bg-danger Admin
                      else if usuario.rol === 'entrenador'
                        span.badge.bg-info Entrenador
                      else
                        span.badge.bg-success Cliente
                    td
                      if usuario.activo
                        span.badge.bg-success Activo
                      else
                        span.badge.bg-secondary Inactivo
                    td.text-muted.small= new Date(usuario.fecha_registro).toLocaleDateString('es-MX')
                    td
                      .btn-group.btn-group-sm
                        a.btn.btn-outline-gold(href=`/admin/usuarios/editar/${usuario.id}`, title='Editar')
                          i.bi.bi-pencil
                        a.btn.btn-outline-danger.btn-delete(href=`/admin/usuarios/eliminar/${usuario.id}`, title='Eliminar')
                          i.bi.bi-trash
              else
                tr
                  td.text-center.text-muted.py-4(colspan='8') No hay usuarios registrados
